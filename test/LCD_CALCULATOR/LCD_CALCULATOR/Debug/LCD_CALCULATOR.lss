// 1. TWI(I2C) 통신 초기화 (SCL 속도를 100kHz로 설정)
void TWI_init(void)
{
    // 16MHz 기준 100kHz 공식: SCL Freq = F_CPU / (16 + 2*TWBR * Prescaler)
    TWBR = 72; // 분주비 1일 때 정확히 100kHz
